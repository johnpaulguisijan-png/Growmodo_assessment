{{ 'shopco.css' | asset_url | stylesheet_tag }}

{%- assign collection = collections[section.settings.collection] -%}
{%- assign products_to_show = section.settings.products_to_show | default: 4 -%}

<div class="sc-divider"></div>

<div class="sc-products">
  <h2 class="sc-section-title">{{ section.settings.title }}</h2>

  <div class="sc-products__grid">
    {%- if collection and collection.products.size > 0 -%}
      {%- for product in collection.products limit: products_to_show -%}
        <a class="sc-product-card" href="{{ product.url }}">
          <div class="sc-product-card__img-wrap">
            {%- if product.featured_image -%}
              <img
                class="sc-product-card__img"
                src="{{ product.featured_image | image_url: width: 600 }}"
                alt="{{ product.featured_image.alt | escape }}"
                loading="lazy"
                width="600"
                height="600"
              >
            {%- else -%}
              <div class="sc-product-card__img-placeholder">
                {{ 'product-apparel-1' | placeholder_svg_tag }}
              </div>
            {%- endif -%}
          </div>

          <p class="sc-product-card__name">{{ product.title | upcase }}</p>

          <div class="sc-product-card__rating">
            <span class="sc-stars" aria-label="4.5 stars">
              {%- for s in (1..4) -%}
                <svg width="18" height="18" viewBox="0 0 18 18" fill="#FFC633" xmlns="http://www.w3.org/2000/svg"><path d="M9 1L11.09 6.26L17 7.27L13 11.14L14.18 17L9 14.27L3.82 17L5 11.14L1 7.27L6.91 6.26L9 1Z"/></svg>
              {%- endfor -%}
            </span>
            <span class="sc-product-card__rating-score">4.5/5</span>
          </div>

          <div class="sc-product-card__pricing">
            <span class="sc-product-card__price">{{ product.price | money }}</span>
            {%- if product.compare_at_price > product.price -%}
              <span class="sc-product-card__compare">{{ product.compare_at_price | money }}</span>
              {%- assign discount = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
              <span class="sc-badge-discount">-{{ discount }}%</span>
            {%- endif -%}
          </div>
        </a>
      {%- endfor -%}
    {%- else -%}
      {%- assign sample_names = "VERTICAL STRIPED SHIRT,COURAGE GRAPHIC T-SHIRT,LOOSE FIT BERMUDA SHORTS,FADED SKINNY JEANS" | split: ',' -%}
      {%- assign sample_prices = "$212,$145,$80,$210" | split: ',' -%}
      {%- assign sample_orig  = "$232,,$," | split: ',' -%}
      {%- for i in (1..4) -%}
        <div class="sc-product-card">
          <div class="sc-product-card__img-wrap">
            <div class="sc-product-card__img-placeholder">
              {{ 'product-apparel-2' | placeholder_svg_tag }}
            </div>
          </div>
          <p class="sc-product-card__name">{{ sample_names[forloop.index0] }}</p>
          <div class="sc-product-card__rating">
            <span class="sc-stars" aria-label="4 stars">
              {%- for s in (1..4) -%}
                <svg width="18" height="18" viewBox="0 0 18 18" fill="#FFC633" xmlns="http://www.w3.org/2000/svg"><path d="M9 1L11.09 6.26L17 7.27L13 11.14L14.18 17L9 14.27L3.82 17L5 11.14L1 7.27L6.91 6.26L9 1Z"/></svg>
              {%- endfor -%}
            </span>
            <span class="sc-product-card__rating-score">4.0/5</span>
          </div>
          <div class="sc-product-card__pricing">
            <span class="sc-product-card__price">{{ sample_prices[forloop.index0] }}</span>
            {%- if forloop.index == 1 -%}
              <span class="sc-product-card__compare">$232</span>
              <span class="sc-badge-discount">-20%</span>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>

  <div class="sc-view-all">
    <a href="{{ section.settings.view_all_link | default: '/collections/all' }}" class="sc-btn sc-btn--outline">
      {{ section.settings.view_all_label | default: 'View All' }}
    </a>
  </div>
</div>

{% schema %}
{
  "name": "Top Selling",
  "tag": "div",
  "class": "shopify-section--top-selling",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section title",
      "default": "TOP SELLING"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 8,
      "step": 1,
      "label": "Products to show",
      "default": 4
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all button label",
      "default": "View All"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View all button link"
    }
  ],
  "presets": [
    {
      "name": "Top Selling"
    }
  ]
}
{% endschema %}
