{{ 'shopco.css' | asset_url | stylesheet_tag }}

<div class="sc-hero-wrapper"
  {%- if section.settings.hero_image -%}
    style="background-image: url('{{ section.settings.hero_image | image_url: width: 1800 }}');"
  {%- endif -%}>

  <section class="sc-hero">

    <!-- LEFT: copy block -->
    <div class="sc-hero__left">
      <h1 class="sc-hero__title">{{ section.settings.title }}</h1>
      <p class="sc-hero__desc">{{ section.settings.description }}</p>
      <a href="{{ section.settings.button_link | default: '/collections/all' }}"
         class="sc-btn sc-btn--primary sc-hero__cta-btn">
        {{ section.settings.button_label | default: 'Shop Now' }}
      </a>

      <div class="sc-hero-stats">
        <div class="sc-hero-stat">
          <strong class="sc-hero-stat__num">{{ section.settings.stat1_number }}</strong>
          <span class="sc-hero-stat__label">{{ section.settings.stat1_label }}</span>
        </div>
        <div class="sc-hero-stat-divider" aria-hidden="true"></div>
        <div class="sc-hero-stat">
          <strong class="sc-hero-stat__num">{{ section.settings.stat2_number }}</strong>
          <span class="sc-hero-stat__label">{{ section.settings.stat2_label }}</span>
        </div>
        <div class="sc-hero-stat-divider" aria-hidden="true"></div>
        <div class="sc-hero-stat">
          <strong class="sc-hero-stat__num">{{ section.settings.stat3_number }}</strong>
          <span class="sc-hero-stat__label">{{ section.settings.stat3_label }}</span>
        </div>
      </div>
    </div>

    <!-- Sparkle decorations (absolute inside .sc-hero) -->
    <span class="sc-sparkle sc-sparkle--lg" aria-hidden="true">
      <svg width="56" height="56" viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M28 0C28 0 30 18 38 26C46 34 56 28 56 28C56 28 38 26 30 34C22 42 28 56 28 56C28 56 26 38 18 30C10 22 0 28 0 28C0 28 18 30 26 22C34 14 28 0 28 0Z" fill="black"/>
      </svg>
    </span>
    <span class="sc-sparkle sc-sparkle--sm" aria-hidden="true">
      <svg width="28" height="28" viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M28 0C28 0 30 18 38 26C46 34 56 28 56 28C56 28 38 26 30 34C22 42 28 56 28 56C28 56 26 38 18 30C10 22 0 28 0 28C0 28 18 30 26 22C34 14 28 0 28 0Z" fill="black"/>
      </svg>
    </span>

  </section>
</div>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "div",
  "class": "shopify-section--hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero background image"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "FIND CLOTHES THAT MATCHES YOUR STYLE"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Browse through our diverse range of meticulously crafted garments, designed to bring out your individuality and cater to your sense of style."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Stats"
    },
    {
      "type": "text",
      "id": "stat1_number",
      "label": "Stat 1 — number",
      "default": "200+"
    },
    {
      "type": "text",
      "id": "stat1_label",
      "label": "Stat 1 — label",
      "default": "International Brands"
    },
    {
      "type": "text",
      "id": "stat2_number",
      "label": "Stat 2 — number",
      "default": "2,000+"
    },
    {
      "type": "text",
      "id": "stat2_label",
      "label": "Stat 2 — label",
      "default": "High-Quality Products"
    },
    {
      "type": "text",
      "id": "stat3_number",
      "label": "Stat 3 — number",
      "default": "30,000+"
    },
    {
      "type": "text",
      "id": "stat3_label",
      "label": "Stat 3 — label",
      "default": "Happy Customers"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
