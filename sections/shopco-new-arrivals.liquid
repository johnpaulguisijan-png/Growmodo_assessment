{{ 'shopco.css' | asset_url | stylesheet_tag }}
{{ 'component-rating.css' | asset_url | stylesheet_tag }}

{%- assign collection = collections[section.settings.collection] -%}
{%- assign products_to_show = section.settings.products_to_show | default: 4 -%}

<div class="sc-products">
  <h2 class="sc-section-title">{{ section.settings.title }}</h2>

  <div class="sc-products__grid">
    {%- if collection and collection.products.size > 0 -%}
      {%- for product in collection.products limit: products_to_show -%}
        {%- render 'shopco-product-card', product: product -%}
      {%- endfor -%}
    {%- else -%}
      {%- for i in (1..4) -%}
        <div class="sc-product-card">
          <div class="sc-product-card__img-wrap sc-product-card__img-placeholder">
            {{ 'product-apparel-1' | placeholder_svg_tag: 'sc-product-card__img' }}
          </div>
          {%- assign sample_names = "T-SHIRT WITH TAPE DETAILS,SKINNY FIT JEANS,CHECKERED SHIRT,SLEEVE STRIPED T-SHIRT" | split: ',' -%}
          {%- assign sample_prices = "$120,$240,$180,$130" | split: ',' -%}
          <p class="sc-product-card__name">{{ sample_names[forloop.index0] }}</p>
          <div class="sc-product-card__rating">
            <span class="sc-stars" aria-label="4.5 out of 5 stars">
              {%- for s in (1..4) -%}
                <svg width="18" height="18" viewBox="0 0 18 18" fill="#FFC633" xmlns="http://www.w3.org/2000/svg"><path d="M9 1L11.09 6.26L17 7.27L13 11.14L14.18 17L9 14.27L3.82 17L5 11.14L1 7.27L6.91 6.26L9 1Z"/></svg>
              {%- endfor -%}
            </span>
            <span class="sc-product-card__rating-score">4.5/5</span>
          </div>
          <div class="sc-product-card__pricing">
            <span class="sc-product-card__price">{{ sample_prices[forloop.index0] }}</span>
          </div>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>

  <div class="sc-view-all">
    <a href="{{ section.settings.view_all_link | default: '/collections/all' }}" class="sc-btn sc-btn--outline">
      {{ section.settings.view_all_label | default: 'View All' }}
    </a>
  </div>
</div>

{% schema %}
{
  "name": "New Arrivals",
  "tag": "div",
  "class": "shopify-section--new-arrivals",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section title",
      "default": "NEW ARRIVALS"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 8,
      "step": 1,
      "label": "Products to show",
      "default": 4
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all button label",
      "default": "View All"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View all button link"
    }
  ],
  "presets": [
    {
      "name": "New Arrivals"
    }
  ]
}
{% endschema %}
