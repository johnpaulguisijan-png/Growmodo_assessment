{{ 'shopco.css' | asset_url | stylesheet_tag }}

<footer class="sc-footer" role="contentinfo">
  <div class="sc-footer__inner">
    <div class="sc-footer__top">
      <!-- Brand column -->
      <div>
        <p class="sc-footer__brand-name">{{ section.settings.brand_name | default: 'SHOP.CO' }}</p>
        <p class="sc-footer__brand-desc">{{ section.settings.brand_description }}</p>
        <div class="sc-footer__socials">
          {%- if settings.social_twitter_link != blank -%}
            <a href="{{ settings.social_twitter_link }}" class="sc-footer__social-link" aria-label="Twitter" target="_blank" rel="noopener">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_facebook_link != blank -%}
            <a href="{{ settings.social_facebook_link }}" class="sc-footer__social-link" aria-label="Facebook" target="_blank" rel="noopener">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_instagram_link != blank -%}
            <a href="{{ settings.social_instagram_link }}" class="sc-footer__social-link" aria-label="Instagram" target="_blank" rel="noopener">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_github_link != blank -%}
            <a href="{{ settings.social_github_link }}" class="sc-footer__social-link" aria-label="GitHub" target="_blank" rel="noopener">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
            </a>
          {%- endif -%}
        </div>
      </div>

      <!-- Link columns -->
      {%- for block in section.blocks -%}
        <div {{ block.shopify_attributes }}>
          <p class="sc-footer__col-title">{{ block.settings.heading }}</p>
          <ul class="sc-footer__links">
            {%- if block.settings.link_1_label != blank -%}
              <li><a class="sc-footer__link" href="{{ block.settings.link_1_url }}">{{ block.settings.link_1_label }}</a></li>
            {%- endif -%}
            {%- if block.settings.link_2_label != blank -%}
              <li><a class="sc-footer__link" href="{{ block.settings.link_2_url }}">{{ block.settings.link_2_label }}</a></li>
            {%- endif -%}
            {%- if block.settings.link_3_label != blank -%}
              <li><a class="sc-footer__link" href="{{ block.settings.link_3_url }}">{{ block.settings.link_3_label }}</a></li>
            {%- endif -%}
            {%- if block.settings.link_4_label != blank -%}
              <li><a class="sc-footer__link" href="{{ block.settings.link_4_url }}">{{ block.settings.link_4_label }}</a></li>
            {%- endif -%}
            {%- if block.settings.link_5_label != blank -%}
              <li><a class="sc-footer__link" href="{{ block.settings.link_5_url }}">{{ block.settings.link_5_label }}</a></li>
            {%- endif -%}
          </ul>
        </div>
      {%- endfor -%}
    </div>

    <div class="sc-footer__bottom">
      <p class="sc-footer__copy">{{ section.settings.copyright_text | default: shop.name | append: ' © 2024. All Rights Reserved' }}</p>
      <div class="sc-footer__payments" aria-label="Accepted payment methods">
        {%- for method in shop.enabled_payment_types -%}
          <span class="sc-footer__payment-badge">{{ method | payment_type_img_url | default: method }}</span>
        {%- else -%}
          <span class="sc-footer__payment-badge">Visa</span>
          <span class="sc-footer__payment-badge">Mastercard</span>
          <span class="sc-footer__payment-badge">PayPal</span>
          <span class="sc-footer__payment-badge">Apple Pay</span>
          <span class="sc-footer__payment-badge">Google Pay</span>
        {%- endfor -%}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Shop.co Footer",
  "tag": "div",
  "class": "shopify-section--sc-footer",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand name",
      "default": "SHOP.CO"
    },
    {
      "type": "textarea",
      "id": "brand_description",
      "label": "Brand description",
      "default": "We have clothes that suits your style and which you're proud to wear. From women to men."
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright text",
      "default": "Shop.co © 2024. All Rights Reserved"
    }
  ],
  "blocks": [
    {
      "type": "link_column",
      "name": "Link Column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Column heading",
          "default": "COMPANY"
        },
        { "type": "text", "id": "link_1_label", "label": "Link 1 label", "default": "About" },
        { "type": "url",  "id": "link_1_url",   "label": "Link 1 URL" },
        { "type": "text", "id": "link_2_label", "label": "Link 2 label", "default": "Features" },
        { "type": "url",  "id": "link_2_url",   "label": "Link 2 URL" },
        { "type": "text", "id": "link_3_label", "label": "Link 3 label", "default": "Works" },
        { "type": "url",  "id": "link_3_url",   "label": "Link 3 URL" },
        { "type": "text", "id": "link_4_label", "label": "Link 4 label", "default": "Career" },
        { "type": "url",  "id": "link_4_url",   "label": "Link 4 URL" },
        { "type": "text", "id": "link_5_label", "label": "Link 5 label" },
        { "type": "url",  "id": "link_5_url",   "label": "Link 5 URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop.co Footer",
      "blocks": [
        {
          "type": "link_column",
          "settings": {
            "heading": "COMPANY",
            "link_1_label": "About", "link_2_label": "Features",
            "link_3_label": "Works", "link_4_label": "Career"
          }
        },
        {
          "type": "link_column",
          "settings": {
            "heading": "HELP",
            "link_1_label": "Customer Support", "link_2_label": "Delivery Details",
            "link_3_label": "Terms & Conditions", "link_4_label": "Privacy Policy"
          }
        },
        {
          "type": "link_column",
          "settings": {
            "heading": "FAQ",
            "link_1_label": "Account", "link_2_label": "Manage Deliveries",
            "link_3_label": "Orders", "link_4_label": "Payments"
          }
        },
        {
          "type": "link_column",
          "settings": {
            "heading": "RESOURCES",
            "link_1_label": "Free eBooks", "link_2_label": "Development Tutorial",
            "link_3_label": "How to - Blog", "link_4_label": "Youtube Playlist"
          }
        }
      ]
    }
  ]
}
{% endschema %}
