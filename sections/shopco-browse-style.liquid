{{ 'shopco.css' | asset_url | stylesheet_tag }}

<div class="sc-styles">
  <div class="sc-styles__container">
    <h2 class="sc-section-title">{{ section.settings.title }}</h2>

    <div class="sc-styles__grid">
      {%- for block in section.blocks -%}
        <a
          class="sc-style-card"
          href="{{ block.settings.link | default: '/collections/all' }}"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.background_image != blank -%}
            <img
              class="sc-style-card__img"
              src="{{ block.settings.background_image | image_url: width: 800 }}"
              alt="{{ block.settings.label | escape }}"
              loading="lazy"
              width="800"
            >
          {%- else -%}
            <div class="sc-style-card__placeholder" style="background:{{ block.settings.placeholder_color | default: '#E8E4E0' }};"></div>
          {%- endif -%}
          <span class="sc-style-card__label">{{ block.settings.label }}</span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Browse by Style",
  "tag": "div",
  "class": "shopify-section--browse-style",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section title",
      "default": "BROWSE BY DRESS STYLE"
    }
  ],
  "blocks": [
    {
      "type": "style_card",
      "name": "Style Card",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Style name",
          "default": "Casual"
        },
        {
          "type": "image_picker",
          "id": "background_image",
          "label": "Background image"
        },
        {
          "type": "color",
          "id": "placeholder_color",
          "label": "Placeholder color",
          "default": "#E8E4E0"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Browse by Style",
      "blocks": [
        { "type": "style_card", "settings": { "label": "Casual", "placeholder_color": "#D6CFC9" } },
        { "type": "style_card", "settings": { "label": "Formal", "placeholder_color": "#C9CFD6" } },
        { "type": "style_card", "settings": { "label": "Party",  "placeholder_color": "#D6C9CF" } },
        { "type": "style_card", "settings": { "label": "Gym",    "placeholder_color": "#CDD6C9" } }
      ]
    }
  ]
}
{% endschema %}
