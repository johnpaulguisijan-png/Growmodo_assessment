{{ 'shopco.css' | asset_url | stylesheet_tag }}

{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign product_form_id = 'sc-product-form-' | append: product.id -%}

<div class="sc-product-page">

  <!-- Breadcrumb -->
  <nav class="sc-coll-breadcrumb" aria-label="Breadcrumb">
    <div class="sc-coll-breadcrumb__wrap">
      <a href="/" class="sc-coll-breadcrumb__link">Home</a>
      <svg width="7" height="12" viewBox="0 0 7 12" fill="none" aria-hidden="true"><path d="M1 1L6 6L1 11" stroke="rgba(0,0,0,0.6)" stroke-width="1.5" stroke-linecap="round"/></svg>
      {%- if product.collections.first -%}
        <a href="{{ product.collections.first.url }}" class="sc-coll-breadcrumb__link">{{ product.collections.first.title }}</a>
        <svg width="7" height="12" viewBox="0 0 7 12" fill="none" aria-hidden="true"><path d="M1 1L6 6L1 11" stroke="rgba(0,0,0,0.6)" stroke-width="1.5" stroke-linecap="round"/></svg>
      {%- endif -%}
      <span class="sc-coll-breadcrumb__current">{{ product.title }}</span>
    </div>
  </nav>

  <!-- ===== PRODUCT LAYOUT: Gallery + Info ===== -->
  <div class="sc-product-layout">

    <!-- GALLERY -->
    <div class="sc-product-gallery">
      <!-- Vertical thumbnail strip -->
      <div class="sc-gallery-thumbs" id="sc-gallery-thumbs">
        {%- if product.images.size > 0 -%}
          {%- for image in product.images limit: 4 -%}
            <button
              type="button"
              class="sc-gallery-thumb{% if forloop.first %} is-active{% endif %}"
              data-src="{{ image | image_url: width: 800 }}"
              aria-label="View image {{ forloop.index }}">
              <img src="{{ image | image_url: width: 120 }}" alt="{{ image.alt | escape }}" loading="lazy">
            </button>
          {%- endfor -%}
        {%- else -%}
          <button type="button" class="sc-gallery-thumb is-active">
            {{ 'product-apparel-1' | placeholder_svg_tag }}
          </button>
        {%- endif -%}
      </div>

      <!-- Main image -->
      <div class="sc-gallery-main">
        {%- if product.featured_image -%}
          <img
            id="sc-gallery-main-img"
            class="sc-gallery-main__img"
            src="{{ product.featured_image | image_url: width: 800 }}"
            alt="{{ product.featured_image.alt | default: product.title | escape }}"
            loading="eager"
            fetchpriority="high">
        {%- else -%}
          <div class="sc-gallery-placeholder">
            {{ 'product-apparel-2' | placeholder_svg_tag }}
          </div>
        {%- endif -%}
      </div>
    </div>

    <!-- PRODUCT INFO -->
    <div class="sc-product-info">

      <h1 class="sc-product-title">{{ product.title | upcase }}</h1>

      <!-- Rating row -->
      <div class="sc-product-rating-row">
        <span class="sc-stars" aria-label="4.5 out of 5 stars">
          {%- for i in (1..4) -%}
            <svg width="18" height="18" viewBox="0 0 18 18" fill="#FFC633"><path d="M9 1L11.09 6.26L17 7.27L13 11.14L14.18 17L9 14.27L3.82 17L5 11.14L1 7.27L6.91 6.26L9 1Z"/></svg>
          {%- endfor -%}
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M9 1L11.09 6.26L17 7.27L13 11.14L14.18 17L9 14.27L3.82 17L5 11.14L1 7.27L6.91 6.26L9 1Z" stroke="#FFC633" stroke-width="1.5"/></svg>
        </span>
        <span class="sc-product-rating-score">4.5<span class="sc-product-rating-max">/5</span></span>
      </div>

      <!-- Price -->
      <div class="sc-product-price-row">
        <span class="sc-product-price" id="sc-product-price">{{ current_variant.price | money_without_trailing_zeros }}</span>
        {%- if current_variant.compare_at_price > current_variant.price -%}
          <span class="sc-product-compare" id="sc-product-compare">{{ current_variant.compare_at_price | money_without_trailing_zeros }}</span>
          {%- assign disc = current_variant.compare_at_price | minus: current_variant.price | times: 100 | divided_by: current_variant.compare_at_price -%}
          <span class="sc-badge-discount" id="sc-product-badge">-{{ disc }}%</span>
        {%- else -%}
          <span class="sc-product-compare" id="sc-product-compare" style="display:none;"></span>
          <span class="sc-badge-discount" id="sc-product-badge" style="display:none;"></span>
        {%- endif -%}
      </div>

      {%- if product.description != blank -%}
        <p class="sc-product-desc">{{ product.description | strip_html | truncate: 220 }}</p>
      {%- endif -%}

      <div class="sc-product-divider"></div>

      <!-- PRODUCT FORM -->
      {%- form 'product', product, id: product_form_id, class: 'sc-product-form' -%}
        <input type="hidden" name="id" id="sc-variant-id" value="{{ current_variant.id }}">

        <!-- OPTIONS: Color + Size -->
        {%- for option in product.options_with_values -%}
          {%- assign opt_down = option.name | downcase -%}

          {%- if opt_down == 'color' or opt_down == 'colour' -%}
            <div class="sc-product-option">
              <p class="sc-product-option__label">
                Select Colors: <strong id="sc-color-label">{{ option.selected_value }}</strong>
              </p>
              <div class="sc-color-swatches sc-color-swatches--pdp">
                {%- for value in option.values -%}
                  <label class="sc-color-swatch sc-color-swatch--pdp" title="{{ value }}">
                    <input type="radio" name="options[{{ option.name | escape }}]"
                           value="{{ value | escape }}"
                           class="sc-color-swatch__input sc-option-input"
                           {% if value == option.selected_value %}checked{% endif %}
                           data-option-index="{{ forloop.parentloop.index0 }}"
                           data-option-value="{{ value | escape }}">
                    <span class="sc-color-swatch__dot sc-color-swatch__dot--lg"
                          style="background: {{ value | downcase | replace: ' ', '' }};"></span>
                  </label>
                {%- endfor -%}
              </div>
            </div>

          {%- elsif opt_down == 'size' -%}
            <div class="sc-product-option">
              <p class="sc-product-option__label">
                Choose Size: <strong id="sc-size-label">{{ option.selected_value }}</strong>
              </p>
              <div class="sc-size-chips sc-size-chips--pdp">
                {%- for value in option.values -%}
                  <label class="sc-size-chip sc-size-chip--pdp">
                    <input type="radio" name="options[{{ option.name | escape }}]"
                           value="{{ value | escape }}"
                           class="sc-size-chip__input sc-option-input"
                           {% if value == option.selected_value %}checked{% endif %}
                           data-option-index="{{ forloop.parentloop.index0 }}"
                           data-option-value="{{ value | escape }}">
                    <span class="sc-size-chip__label{% if value == option.selected_value %} is-selected{% endif %}">{{ value }}</span>
                  </label>
                {%- endfor -%}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}

        <div class="sc-product-divider"></div>

        <!-- QUANTITY + ADD TO CART -->
        <div class="sc-product-actions">
          <div class="sc-qty-wrap">
            <button type="button" class="sc-qty-btn" id="sc-qty-minus" aria-label="Decrease quantity">−</button>
            <input type="number" name="quantity" value="1" min="1" class="sc-qty-input" id="sc-qty-input" aria-label="Quantity">
            <button type="button" class="sc-qty-btn" id="sc-qty-plus" aria-label="Increase quantity">+</button>
          </div>
          <button type="submit" name="add" id="sc-add-to-cart"
                  class="sc-btn sc-btn--primary sc-add-to-cart"
                  {% unless current_variant.available or current_variant.inventory_policy == 'continue' %}disabled{% endunless %}>
            {%- if current_variant.available or current_variant.inventory_policy == 'continue' -%}Add to Cart{%- else -%}Sold Out{%- endif -%}
          </button>
        </div>
        <div id="sc-atc-message" class="sc-atc-message" aria-live="polite" style="display:none;"></div>
      {%- endform -%}

      <!-- Shipping / Return info -->
      <div class="sc-product-shipping">
        <div class="sc-product-shipping__item">
          <span class="sc-product-shipping__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="1" y="3" width="14" height="12" rx="1" stroke="#000" stroke-width="1.5"/><path d="M15 7H18.5L22 11V15H15V7Z" stroke="#000" stroke-width="1.5" stroke-linejoin="round"/><circle cx="4.5" cy="17.5" r="1.5" stroke="#000" stroke-width="1.5"/><circle cx="18.5" cy="17.5" r="1.5" stroke="#000" stroke-width="1.5"/></svg>
          </span>
          <div class="sc-product-shipping__text">
            <strong>Free Delivery</strong>
            <span>Enter your postal code for delivery availability</span>
          </div>
        </div>
        <div class="sc-product-divider"></div>
        <div class="sc-product-shipping__item">
          <span class="sc-product-shipping__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M3 12H21M12 21L21 12L12 3" stroke="#000" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          <div class="sc-product-shipping__text">
            <strong>Return Delivery</strong>
            <span>Free 30 Days Delivery Returns. <a href="/policies/refund-policy" class="sc-product-shipping__link">Details</a></span>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- ===== TABS: Details | Reviews | FAQ ===== -->
  <div class="sc-product-tabs-wrap">
    <div class="sc-product-tabs" role="tablist">
      <button class="sc-tab-btn is-active" data-tab="details" role="tab" aria-selected="true">Product Details</button>
      <button class="sc-tab-btn" data-tab="reviews" role="tab" aria-selected="false">Rating &amp; Reviews</button>
      <button class="sc-tab-btn" data-tab="faq" role="tab" aria-selected="false">FAQs</button>
    </div>

    <!-- Details tab -->
    <div class="sc-tab-pane" id="sc-tab-details" role="tabpanel">
      <div class="sc-product-details-body">
        {%- if product.description != blank -%}
          {{ product.description }}
        {%- else -%}
          <p>No product details available.</p>
        {%- endif -%}
      </div>
    </div>

    <!-- Reviews tab -->
    <div class="sc-tab-pane" id="sc-tab-reviews" role="tabpanel" style="display:none;">
      <div class="sc-pdp-reviews-header">
        <div class="sc-pdp-reviews-summary">
          <span class="sc-pdp-reviews-avg">4.5/5</span>
          <span class="sc-stars" aria-label="4.5 stars">
            {%- for i in (1..4) -%}
              <svg width="22" height="22" viewBox="0 0 18 18" fill="#FFC633"><path d="M9 1L11.09 6.26L17 7.27L13 11.14L14.18 17L9 14.27L3.82 17L5 11.14L1 7.27L6.91 6.26L9 1Z"/></svg>
            {%- endfor -%}
            <svg width="22" height="22" viewBox="0 0 18 18" fill="none"><path d="M9 1L11.09 6.26L17 7.27L13 11.14L14.18 17L9 14.27L3.82 17L5 11.14L1 7.27L6.91 6.26L9 1Z" stroke="#FFC633" stroke-width="1.5"/></svg>
          </span>
          <span class="sc-pdp-reviews-count">Based on 128 Reviews</span>
        </div>
        <button class="sc-btn sc-btn--outline" type="button">Write a Review</button>
      </div>

      <div class="sc-pdp-reviews-grid">
        {%- assign review_names = "Samantha D.,Alex K.,James L.,Maria R.,David W.,Emma T." | split: ',' -%}
        {%- assign review_texts = "I absolutely love this t-shirt! The design is unique and the fabric feels so comfortable. It has become my favorite go-to shirt.,The quality of this shirt is exceptional! The stitching is precise and the fabric is breathable. Highly recommend.,This shirt exceeded my expectations! The colors are vibrant and it fits perfectly.,I was a bit skeptical at first but I'm so glad I ordered. The material is premium quality.,Great product! Fast shipping and the packaging was excellent. Will definitely buy again.,Love the design and the fit. The shirt looks exactly like the pictures on the website." | split: ',' -%}
        {%- assign review_dates = "Posted on August 14, 2023,Posted on August 18, 2023,Posted on August 22, 2023,Posted on September 1, 2023,Posted on September 5, 2023,Posted on September 10, 2023" | split: ',' -%}
        {%- assign review_stars = "5,4,5,4,5,4" | split: ',' -%}

        {%- for name in review_names -%}
          {%- assign star_count = review_stars[forloop.index0] | plus: 0 -%}
          <div class="sc-review-card sc-review-card--pdp">
            <div class="sc-review-card__head">
              <span class="sc-stars" aria-label="{{ star_count }} stars">
                {%- for s in (1..star_count) -%}
                  <svg width="16" height="16" viewBox="0 0 18 18" fill="#FFC633"><path d="M9 1L11.09 6.26L17 7.27L13 11.14L14.18 17L9 14.27L3.82 17L5 11.14L1 7.27L6.91 6.26L9 1Z"/></svg>
                {%- endfor -%}
              </span>
              <span class="sc-review-card__verified">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><circle cx="7" cy="7" r="7" fill="#01AB31"/><path d="M4 7L6 9L10 5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Verified
              </span>
            </div>
            <p class="sc-review-card__author"><strong>{{ name }}</strong></p>
            <p class="sc-review-card__text">"{{ review_texts[forloop.index0] }}"</p>
            <p class="sc-review-card__date">{{ review_dates[forloop.index0] }}</p>
          </div>
        {%- endfor -%}
      </div>

      <div class="sc-pdp-reviews-load-more">
        <button class="sc-btn sc-btn--outline" type="button">Load More Reviews</button>
      </div>
    </div>

    <!-- FAQ tab -->
    <div class="sc-tab-pane" id="sc-tab-faq" role="tabpanel" style="display:none;">
      <div class="sc-faq-list">
        {%- assign faq_questions = "What is the return policy?,How long does shipping take?,Are there any discount codes available?,How do I care for this garment?,Do you ship internationally?" | split: ',' -%}
        {%- assign faq_answers = "We offer a free 30-day return policy on all items. Items must be unworn and in their original condition with all tags attached.,Standard shipping takes 5-7 business days. Express shipping (2-3 days) is also available at checkout.,Yes! Sign up for our newsletter and receive 20% off your first order. Follow us on social media for seasonal promotions.,Machine wash cold with like colors. Tumble dry on low heat. Do not bleach. Iron on low heat if needed.,Yes, we ship to most countries worldwide. International shipping times vary by destination (typically 7-14 business days)." | split: ',' -%}
        {%- for question in faq_questions -%}
          <div class="sc-faq-item">
            <button class="sc-faq-question" type="button">
              <span>{{ question }}</span>
              <svg class="sc-faq-chev" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M4 6L8 10L12 6" stroke="#000" stroke-width="1.5" stroke-linecap="round"/></svg>
            </button>
            <div class="sc-faq-answer">
              <p>{{ faq_answers[forloop.index0] }}</p>
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>

  <!-- ===== YOU MIGHT ALSO LIKE ===== -->
  {%- assign related_collection = product.collections.first -%}
  {%- if related_collection and related_collection.products.size > 1 -%}
    <div class="sc-products sc-products--related">
      <h2 class="sc-section-title">YOU MIGHT ALSO LIKE</h2>
      <div class="sc-products__grid">
        {%- assign shown = 0 -%}
        {%- for p in related_collection.products -%}
          {%- if p.id != product.id and shown < 4 -%}
            {%- render 'shopco-product-card', product: p -%}
            {%- assign shown = shown | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

</div>

<script>
(function () {
  'use strict';

  // ---- Image gallery ----
  var thumbs = document.querySelectorAll('.sc-gallery-thumb');
  var mainImg = document.getElementById('sc-gallery-main-img');

  thumbs.forEach(function (thumb) {
    thumb.addEventListener('click', function () {
      thumbs.forEach(function (t) { t.classList.remove('is-active'); });
      this.classList.add('is-active');
      if (mainImg && this.dataset.src) {
        mainImg.src = this.dataset.src;
      }
    });
  });

  // ---- Quantity selector ----
  var qtyInput = document.getElementById('sc-qty-input');
  var minusBtn = document.getElementById('sc-qty-minus');
  var plusBtn  = document.getElementById('sc-qty-plus');

  minusBtn && minusBtn.addEventListener('click', function () {
    var v = parseInt(qtyInput.value, 10);
    if (v > 1) qtyInput.value = v - 1;
  });
  plusBtn && plusBtn.addEventListener('click', function () {
    qtyInput.value = parseInt(qtyInput.value, 10) + 1;
  });

  // ---- Variant selection ----
  var variants = {{ product.variants | json }};

  var selectedOptions = [
    {%- for option in product.options_with_values -%}
      "{{ option.selected_value | escape }}"{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ];

  function formatMoney(cents) {
    var dollars = cents / 100;
    return '$' + (dollars % 1 === 0 ? dollars.toFixed(0) : dollars.toFixed(2));
  }

  function findVariant() {
    return variants.find(function (v) {
      return v.options.every(function (o, i) { return o === selectedOptions[i]; });
    });
  }

  function updateVariant() {
    var variant = findVariant();
    if (!variant) return;

    // Update hidden form input
    var idInput = document.getElementById('sc-variant-id');
    if (idInput) idInput.value = variant.id;

    // Update price
    var priceEl   = document.getElementById('sc-product-price');
    var compareEl = document.getElementById('sc-product-compare');
    var badgeEl   = document.getElementById('sc-product-badge');
    var addBtn    = document.getElementById('sc-add-to-cart');

    if (priceEl) priceEl.textContent = formatMoney(variant.price);

    if (variant.compare_at_price && variant.compare_at_price > variant.price) {
      if (compareEl) { compareEl.textContent = formatMoney(variant.compare_at_price); compareEl.style.display = ''; }
      if (badgeEl) {
        var pct = Math.round((variant.compare_at_price - variant.price) / variant.compare_at_price * 100);
        badgeEl.textContent = '-' + pct + '%';
        badgeEl.style.display = '';
      }
    } else {
      if (compareEl) compareEl.style.display = 'none';
      if (badgeEl) badgeEl.style.display = 'none';
    }

    // Update add to cart button
    if (addBtn) {
      var canAdd = variant.available || variant.inventory_policy === 'continue';
      addBtn.disabled = !canAdd;
      addBtn.textContent = canAdd ? 'Add to Cart' : 'Sold Out';
    }

    // Update URL without reload
    var url = new URL(window.location.href);
    url.searchParams.set('variant', variant.id);
    window.history.replaceState({}, '', url.toString());
  }

  // Color swatches
  document.querySelectorAll('.sc-color-swatch__input.sc-option-input').forEach(function (inp) {
    inp.addEventListener('change', function () {
      selectedOptions[parseInt(this.dataset.optionIndex, 10)] = this.dataset.optionValue;
      var lbl = document.getElementById('sc-color-label');
      if (lbl) lbl.textContent = this.dataset.optionValue;
      updateVariant();
    });
  });

  // Size chips
  document.querySelectorAll('.sc-size-chip--pdp .sc-size-chip__input').forEach(function (inp) {
    inp.addEventListener('change', function () {
      selectedOptions[parseInt(this.dataset.optionIndex, 10)] = this.dataset.optionValue;
      document.querySelectorAll('.sc-size-chip--pdp .sc-size-chip__label').forEach(function (l) {
        l.classList.remove('is-selected');
      });
      this.closest('.sc-size-chip--pdp').querySelector('.sc-size-chip__label').classList.add('is-selected');
      var lbl = document.getElementById('sc-size-label');
      if (lbl) lbl.textContent = this.dataset.optionValue;
      updateVariant();
    });
  });

  // ---- AJAX Add to Cart ----
  var productForm = document.getElementById('{{ product_form_id }}');
  var atcMsg      = document.getElementById('sc-atc-message');
  var addBtn      = document.getElementById('sc-add-to-cart');

  function showMsg(text, isError) {
    if (!atcMsg) return;
    atcMsg.textContent = text;
    atcMsg.style.display = 'block';
    atcMsg.className = 'sc-atc-message ' + (isError ? 'sc-atc-message--error' : 'sc-atc-message--success');
    clearTimeout(atcMsg._timer);
    atcMsg._timer = setTimeout(function () { atcMsg.style.display = 'none'; }, 4000);
  }

  if (productForm) {
    productForm.addEventListener('submit', function (e) {
      e.preventDefault();
      if (addBtn && addBtn.disabled) return;

      var variantId  = parseInt(document.getElementById('sc-variant-id').value, 10);
      var quantity   = parseInt(document.getElementById('sc-qty-input').value, 10) || 1;
      var origText   = addBtn ? addBtn.textContent : 'Add to Cart';

      if (!variantId) { showMsg('Please select a variant.', true); return; }

      if (addBtn) { addBtn.disabled = true; addBtn.textContent = 'Adding...'; }

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ id: variantId, quantity: quantity })
      })
        .then(function (res) {
          if (!res.ok) return res.json().then(function (d) { throw new Error(d.description || 'Could not add to cart.'); });
          return res.json();
        })
        .then(function () {
          showMsg('Added to cart!', false);
          fetch('/cart.js')
            .then(function (r) { return r.json(); })
            .then(function (cart) {
              var bubbles = document.querySelectorAll('.cart-count-bubble span[aria-hidden]');
              bubbles.forEach(function (b) { b.textContent = cart.item_count; });
            });
        })
        .catch(function (err) {
          showMsg(err.message, true);
        })
        .finally(function () {
          if (addBtn) { addBtn.disabled = false; addBtn.textContent = origText; }
        });
    });
  }

  // ---- Tabs ----
  document.querySelectorAll('.sc-tab-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      document.querySelectorAll('.sc-tab-btn').forEach(function (b) {
        b.classList.remove('is-active');
        b.setAttribute('aria-selected', 'false');
      });
      document.querySelectorAll('.sc-tab-pane').forEach(function (p) {
        p.style.display = 'none';
      });
      this.classList.add('is-active');
      this.setAttribute('aria-selected', 'true');
      var pane = document.getElementById('sc-tab-' + this.dataset.tab);
      if (pane) pane.style.display = '';
    });
  });

  // ---- FAQ accordion ----
  document.querySelectorAll('.sc-faq-question').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var ans  = this.nextElementSibling;
      var chev = this.querySelector('.sc-faq-chev');
      var open = ans.style.display !== 'none' && ans.style.display !== '';
      ans.style.display = open ? 'none' : '';
      if (chev) chev.style.transform = open ? '' : 'rotate(180deg)';
    });
  });

})();
</script>

{% schema %}
{
  "name": "Product Page",
  "settings": [],
  "presets": [
    {
      "name": "Product Page"
    }
  ]
}
{% endschema %}
